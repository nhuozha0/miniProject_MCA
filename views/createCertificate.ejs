<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="UTF-8">

    <meta
        name="viewport"
        content="width=device-width, initial-scale=1.0">

    <title>
        Create Certificate
    </title>

    <link
        href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
        rel="stylesheet">

    <link
        rel="stylesheet"
        href="/css/style.css">

</head>

<body>

<%- include('partials/navbar') %>

<div class="create-certificate-page">

    <div class="create-certificate-card">

        <div class="page-header">

            <div class="page-icon">
                📜
            </div>

            <h1>
                Create New Certificate
            </h1>

            <p>
                Generate and store a new certificate securely on the blockchain.
            </p>

        </div>

        <form
            action="/create-certificate"
            method="POST">

            <div class="form-group mb-4">

                <label>
                    Student Name
                </label>

                <input
                    type="text"
                    name="student_name"
                    class="form-control modern-input"
                    placeholder="Enter Student Name"
                    required>

            </div>

            <div class="form-group mb-4">

                <label>
                    Course Name
                </label>

                <input
                    type="text"
                    name="course_name"
                    class="form-control modern-input"
                    placeholder="Enter Course Name"
                    required>

            </div>

            <div class="form-group mb-4">

                <label>
                    Issue Date
                </label>

                <input
                    type="date"
                    name="issue_date"
                    class="form-control modern-input"
                    required>

            </div>

            

            <div class="action-area">
                <a
                    href="/dashboard"
                    class="dashboard-btn">

                    Back to Dashboard

                </a>
                <button
                    type="submit"
                    class="generate-btn">

                    Generate Certificate

                </button>

               

            </div>

        </form>

    </div>

</div>

</body>

</html>