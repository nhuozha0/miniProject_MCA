<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="UTF-8">

    <meta
        name="viewport"
        content="width=device-width, initial-scale=1.0">

    <title>
        Certificate Management
    </title>

    <link
        href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
        rel="stylesheet">

    <style>

        .card-hover:hover {
            transform: translateY(-3px);
            transition: 0.2s;
        }

    </style>

</head>

<body class="bg-light">

<%- include('partials/navbar') %>

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>

            <h2 class="fw-bold">
                Certificate Management
            </h2>

            <p class="text-muted mb-0">
                Manage issued certificates
            </p>

        </div>

        <a
            href="/create-certificate"
            class="btn btn-success">

            + Create Certificate

        </a>

    </div>

    <!-- Summary Card -->

    <div class="row mb-4">

        <div class="col-md-4">

            <div class="card shadow-sm card-hover">

                <div class="card-body text-center">

                    <h6 class="text-muted">
                        Certificates Displayed
                    </h6>

                    <h2 class="fw-bold">
                        <%= certificates.length %>
                    </h2>

                </div>

            </div>

        </div>

    </div>

    <!-- Search Card -->

    <div class="card shadow-sm mb-4">

        <div class="card-body">

            <form
                action="/certificates"
                method="GET">

                <div class="row">

                    <div class="col-md-10">

                        <input
                            type="text"
                            name="search"
                            class="form-control"
                            placeholder="Search by Certificate ID or Student Name"
                            value="<%= search %>">

                    </div>

                    <div class="col-md-2">

                        <button
                            type="submit"
                            class="btn btn-primary w-100">

                            Search

                        </button>

                    </div>

                </div>

            </form>

        </div>

    </div>

    <!-- Certificate Table -->

    <div class="card shadow">

        <div class="card-body">

            <div class="table-responsive">

                <table class="table table-hover align-middle">

                    <thead class="table-dark">

                        <tr>

                            <th>Block</th>
                            <th>Certificate ID</th>
                            <th>Student</th>
                            <th>Course</th>
                            <th>Status</th>
                            <th width="250">
                                Actions
                            </th>

                        </tr>

                    </thead>

                    <tbody>

                    <% if(certificates.length === 0){ %>

                        <tr>

                            <td
                                colspan="6"
                                class="text-center py-4">

                                No certificates found.

                            </td>

                        </tr>

                    <% } %>

                    <% certificates.forEach(certificate => { %>

                        <tr>

                            <td>

                                <span class="badge bg-secondary">

                                    #<%= certificate.block_number %>

                                </span>

                            </td>

                            <td>

                                <strong>
                                    <%= certificate.certificate_id %>
                                </strong>

                            </td>

                            <td>
                                <%= certificate.student_name %>
                            </td>

                            <td>
                                <%= certificate.course_name %>
                            </td>

                            <td>

                                <% if(certificate.status === 'VALID'){ %>

                                    <span class="badge bg-success">

                                        VALID

                                    </span>

                                <% } else { %>

                                    <span class="badge bg-danger">

                                        REVOKED

                                    </span>

                                <% } %>

                            </td>

                            <td>

                                <a
                                    href="/certificate/<%= certificate.id %>"
                                    class="btn btn-sm btn-primary">

                                    View

                                </a>

                                <a
                                    href="/download/<%= certificate.certificate_id %>"
                                    class="btn btn-sm btn-success">

                                    PDF

                                </a>

                                <% if(certificate.status === 'VALID'){ %>

                                    <a
                                        href="/revoke-certificate/<%= certificate.id %>"
                                        class="btn btn-sm btn-danger"
                                        onclick="return confirm('Revoke this certificate?')">

                                        Revoke

                                    </a>

                                <% } %>

                            </td>

                        </tr>

                    <% }) %>

                    </tbody>

                </table>

            </div>

        </div>

    </div>

    <div class="mt-3">

        <a
            href="/dashboard"
            class="btn btn-secondary">

            ← Back To Dashboard

        </a>

    </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>