<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="UTF-8">

    <meta
        name="viewport"
        content="width=device-width, initial-scale=1.0">

    <title>
        Certificate Verification
    </title>

    <link
        href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
        rel="stylesheet">

    <link
        rel="stylesheet"
        href="/css/style.css">

</head>

<body>

<%- include('partials/navbar') %>

<div class="verify-page">

    <div class="verify-card">

        <div class="verify-header">

            <div class="verify-icon">
                🔍
            </div>

            <h1>
                Certificate Verification
            </h1>

            <p>
                Verify the authenticity and blockchain integrity of certificates.
            </p>

        </div>

        <form
            action="/verify"
            method="POST">

            <div class="verify-search">

                <input
                    type="text"
                    name="certificate_id"
                    class="verify-input"
                    placeholder="Enter Certificate ID"
                    required>

                <button
                    type="submit"
                    class="verify-btn">

                    Verify

                </button>

            </div>

        </form>

        <div class="verify-navigation">

            <a
                href="/dashboard"
                class="dashboard-btn">

                Back to Dashboard

            </a>

        </div>

        <% if(result){ %>

            <!-- VALID -->

            <% if(result.status === 'VALID'){ %>

                <div class="verify-status success-status">

                    <div class="status-icon-box">
                        ✓
                    </div>

                    <div>

                        <h3>
                            Valid Certificate
                        </h3>

                        <p>
                            Certificate integrity verified successfully.
                        </p>

                    </div>

                </div>

                <div class="certificate-info">

                    <div class="info-row">
                        <span>Certificate ID</span>
                        <strong><%= result.certificate.certificate_id %></strong>
                    </div>

                    <div class="info-row">
                        <span>Student Name</span>
                        <strong><%= result.certificate.student_name %></strong>
                    </div>

                    <div class="info-row">
                        <span>Course Name</span>
                        <strong><%= result.certificate.course_name %></strong>
                    </div>

                    <div class="info-row">
                        <span>Issue Date</span>
                        <strong><%= result.certificate.issue_date.toISOString().split('T')[0] %></strong>
                    </div>

                    <div class="info-row">
                        <span>Block Number</span>
                        <strong><%= result.certificate.block_number %></strong>
                    </div>

                </div>

            <% } %>

            <!-- REVOKED -->

            <% if(result.status === 'REVOKED'){ %>

                <div class="verify-status danger-status">

                    <div class="status-icon-box">
                        🚫
                    </div>

                    <div>

                        <h3>
                            Certificate Revoked
                        </h3>

                        <p>
                            This certificate has been revoked and is no longer valid.
                        </p>

                    </div>

                </div>

            <% } %>

            <!-- TAMPERED -->

            <% if(result.status === 'TAMPERED'){ %>

                <div class="verify-status warning-status">

                    <div class="status-icon-box">
                        ⚠
                    </div>

                    <div>

                        <h3>
                            Certificate Tampered
                        </h3>

                        <p>
                            Certificate data integrity check failed.
                        </p>

                    </div>

                </div>

            <% } %>

            <!-- CHAIN BROKEN -->

            <% if(result.status === 'CHAIN_BROKEN'){ %>

                <div class="verify-status danger-status">

                    <div class="status-icon-box">
                        ⛓
                    </div>

                    <div>

                        <h3>
                            Blockchain Chain Broken
                        </h3>

                        <p>
                            Hash chain validation failed.
                        </p>

                    </div>

                </div>

            <% } %>

            <!-- NOT FOUND -->

            <% if(result.status === 'NOT_FOUND'){ %>

                <div class="verify-status neutral-status">

                    <div class="status-icon-box">
                        ✖
                    </div>

                    <div>

                        <h3>
                            Certificate Not Found
                        </h3>

                        <p>
                            No certificate exists with the provided Certificate ID.
                        </p>

                    </div>

                </div>

            <% } %>

        <% } %>

    </div>

</div>

</body>

</html>