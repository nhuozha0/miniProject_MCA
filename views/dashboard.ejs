<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="UTF-8">

    <meta
        name="viewport"
        content="width=device-width, initial-scale=1.0">

    <title>Admin Dashboard</title>

    <link
        href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
        rel="stylesheet">

    <link rel="stylesheet" href="/css/style.css">

</head>

<body>

<%- include('partials/navbar') %>

<div class="dashboard-wrapper">

    <div class="dashboard-header">

        <h1>
            Dashboard Overview
        </h1>

        <p>
            Monitor your blockchain certificate verification system in real-time
        </p>

    </div>

    <!-- Statistics -->

    <div class="stats-grid">

        <div class="stat-card">

            <div class="card-top">

                <div class="icon purple">
                    📄
                </div>

                <span class="badge-soft">
                    Total
                </span>

            </div>

            <h2>
                <%= totalCertificates %>
            </h2>

            <p>
                Certificates
            </p>

        </div>

        <div class="stat-card">

            <div class="card-top">

                <div class="icon green">
                    ✓
                </div>

                <span class="badge-soft success">
                    Active
                </span>

            </div>

            <h2 class="text-success">
                <%= validCertificates %>
            </h2>

            <p>
                Valid Certificates
            </p>

        </div>

        <div class="stat-card">

            <div class="card-top">

                <div class="icon red">
                    ✕
                </div>

                <span class="badge-soft danger">
                    Revoked
                </span>

            </div>

            <h2 class="text-danger">
                <%= revokedCertificates %>
            </h2>

            <p>
                Revoked Certificates
            </p>

        </div>

        <div class="stat-card">

            <div class="card-top">

                <div class="icon purple">
                    🔗
                </div>

                <span class="badge-soft">
                    Latest
                </span>

            </div>

            <h2 class="text-primary">
                #<%= latestBlock %>
            </h2>

            <p>
                Latest Block
            </p>

        </div>

    </div>

    <!-- Bottom Section -->

    <div class="bottom-grid">

        <!-- Blockchain Health -->

        <div class="health-card">

            <h3>
                Blockchain Status
            </h3>

            <% if(blockchainHealthy) { %>

                <div class="health-status">

                    <div class="status-icon">

                        ✓

                    </div>

                    <div>

                        <h2 class="healthy-text">
                            Healthy
                        </h2>

                        <p>
                            All blocks and hash chains are valid.
                        </p>

                    </div>

                </div>

            <% } else { %>

                <div class="health-status">

                    <div class="status-icon danger-bg">

                        ✕

                    </div>

                    <div>

                        <h2 class="text-danger">
                            Compromised
                        </h2>

                        <p>
                            Blockchain integrity validation failed.
                        </p>

                    </div>

                </div>

            <% } %>

        </div>

        <!-- Quick Actions -->

        <div class="actions-card">

            <h3>
        <!-- Quick Actions -->

<div class="actions-card">

    <h3>
        Quick Actions
    </h3>

    <div class="action-grid">

        <a
            href="/create-certificate"
            class="action-btn create-btn">

            Create Certificate

        </a>

        <a
            href="/certificates"
            class="action-btn cert-btn">

            View Certificates

        </a>

       <a
    href="/verify"
    class="action-btn dashboard-verify-btn">

    Verify Certificate

</a>

        <a
            href="/blockchain"
            class="action-btn blockchain-btn">

            Blockchain Explorer

        </a>

        <a
            href="/validate-blockchain"
            class="action-btn validate-btn">

            Validate Blockchain

        </a>

    </div>

</div>

    </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>