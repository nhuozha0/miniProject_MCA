<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="UTF-8">

    <meta
        name="viewport"
        content="width=device-width, initial-scale=1.0">

    <title>
        Certificate Details
    </title>

    <link
        href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
        rel="stylesheet">

    <link
        rel="stylesheet"
        href="/css/style.css">

        <script>

function copyCertificateId(id, button){

    navigator.clipboard.writeText(id);

    button.innerText = "Copied";

    button.classList.add("copied");

    setTimeout(() => {

        button.innerText = "Copy";

        button.classList.remove("copied");

    }, 1500);

}

</script>

</head>

<body>

<%- include('partials/navbar') %>

<div class="certificate-page">

    <div class="certificate-card">

        <div class="certificate-header">

            <div>

                <h1>
                    Certificate Details
                </h1>

                <p>
                    View blockchain certificate information and verification data.
                </p>

            </div>

            <div class="certificate-badge">
                Verified Record
            </div>

        </div>

        <div class="details-grid">

            <div class="detail-item">

                <span class="detail-label">
                    Block Number
                </span>

                <span class="detail-value">
                    <%= certificate.block_number %>
                </span>

            </div>

           <div class="detail-item">

    <span class="detail-label">
        Certificate ID
    </span>

    <div class="certificate-id-row">

        <span class="detail-value">
            <%= certificate.certificate_id %>
        </span>

        <button
            type="button"
            class="copy-id-btn"
            onclick="copyCertificateId('<%= certificate.certificate_id %>', this)">

            Copy

        </button>

    </div>

</div>

            <div class="detail-item">

                <span class="detail-label">
                    Student Name
                </span>

                <span class="detail-value">
                    <%= certificate.student_name %>
                </span>

            </div>

            <div class="detail-item">

                <span class="detail-label">
                    Course Name
                </span>

                <span class="detail-value">
                    <%= certificate.course_name %>
                </span>

            </div>

            <div class="detail-item">

                <span class="detail-label">
                    Issue Date
                </span>

                <span class="detail-value">
                    <%= certificate.issue_date.toLocaleDateString('en-CA') %>
                </span>

            </div>

        </div>

        <div class="hash-section">

            <h4>
                Current Hash
            </h4>

            <div class="hash-box">
                <%= certificate.current_hash %>
            </div>

        </div>

        <div class="hash-section">

            <h4>
                Previous Hash
            </h4>

            <div class="hash-box">
                <%= certificate.previous_hash %>
            </div>

        </div>

        <div class="action-buttons">

            <a
                href="/download/<%= certificate.certificate_id %>"
                class="download-btn">

                Download PDF Certificate

            </a>

            <a
                href="/certificates"
                class="back-btn">

                Back To List

            </a>

        </div>

    </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>