<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="UTF-8">

    <meta
        name="viewport"
        content="width=device-width, initial-scale=1.0">

    <title>
        Blockchain Explorer
    </title>

    <link
        href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
        rel="stylesheet">

    <link
        rel="stylesheet"
        href="/css/style.css">

</head>

<body>

<%- include('partials/navbar') %>

<div class="blockchain-page">

    <div class="explorer-header">

        <div>

            <h1>
                Blockchain Explorer
            </h1>

            <p>
                Explore certificate blocks and blockchain relationships.
            </p>

        </div>

        <a
            href="/dashboard"
            class="dashboard-btn">

            Back to Dashboard

        </a>

    </div>

    <% if(blocks.length === 0){ %>

        <div class="empty-chain">

            <h3>
                No Blocks Found
            </h3>

            <p>
                The blockchain currently contains no blocks.
            </p>

        </div>

    <% } %>

    <div class="blockchain-timeline">

        <% blocks.forEach((block,index)=>{ %>

            <div class="block-node">

                <div class="chain-dot">
                    <%= block.block_number %>
                </div>

                <div class="block-card">

                    <div class="block-card-header">

                        <div>

                            <h4>
                                Block #<%= block.block_number %>
                            </h4>

                            <span class="certificate-tag">
                                <%= block.certificate_id %>
                            </span>

                        </div>

                        <% if(block.status === 'VALID'){ %>

                            <span class="status-valid">
                                VALID
                            </span>

                        <% } else { %>

                            <span class="status-revoked">
                                REVOKED
                            </span>

                        <% } %>

                    </div>

                    <div class="block-info-grid">

                        <div class="info-box">

                            <span>Student Name</span>

                            <strong>
                                <%= block.student_name %>
                            </strong>

                        </div>

                        <div class="info-box">

                            <span>Course Name</span>

                            <strong>
                                <%= block.course_name %>
                            </strong>

                        </div>

                        <div class="info-box">

                            <span>Issue Date</span>

                            <strong>
                                <%= new Date(block.issue_date).toISOString().split('T')[0] %>
                            </strong>

                        </div>

                        <div class="info-box">

                            <span>Status</span>

                            <strong>
                                <%= block.status %>
                            </strong>

                        </div>

                    </div>

                    <div class="hash-section">

                        <h6>
                            Previous Hash
                        </h6>

                        <div class="hash-box">
                            <%= block.previous_hash %>
                        </div>

                    </div>

                    <div class="hash-section">

                        <h6>
                            Current Hash
                        </h6>

                        <div class="hash-box current">
                            <%= block.current_hash %>
                        </div>

                    </div>

                </div>

            </div>

        <% }) %>

    </div>

</div>

</body>

</html>